# flake.nix
# Quickstart overlay generated by `tsurf init` for fast evaluation on an existing NixOS host.
# @decision ONBOARD-201-01: Quickstart overlay is path-based and intentionally local-first to minimize first-run setup friction.
{
  inputs = {
    tsurf.url = "__TSURF_SOURCE__";

    nixpkgs.follows = "tsurf/nixpkgs";
    llm-agents.follows = "tsurf/llm-agents";
    deploy-rs.follows = "tsurf/deploy-rs";
    impermanence.follows = "tsurf/impermanence";
    srvos.follows = "tsurf/srvos";
    nix-mineral.follows = "tsurf/nix-mineral";
  };

  outputs =
    {
      self,
      nixpkgs,
      llm-agents,
      deploy-rs,
      impermanence,
      srvos,
      nix-mineral,
      tsurf,
      ...
    }:
    let
      system = "__TSURF_SYSTEM__";
      lib = nixpkgs.lib;
    in
    {
      nixosConfigurations."__TSURF_NODE__" = nixpkgs.lib.nixosSystem {
        inherit system;
        modules = [
          srvos.nixosModules.server
          impermanence.nixosModules.impermanence
          nix-mineral.nixosModules.nix-mineral
          {
            options.services.resolved.settings = lib.mkOption {
              type = lib.types.anything;
              default = { };
            };
          }
          {
            nixpkgs.overlays = [
              llm-agents.overlays.default
              tsurf.overlays.default
            ];
          }
          "${tsurf}/modules/base.nix"
          "${tsurf}/modules/users.nix"
          "${tsurf}/modules/networking.nix"
          "${tsurf}/modules/impermanence.nix"
          "${tsurf}/modules/agent-compute.nix"
          { services.agentCompute.enable = true; }
          "${tsurf}/modules/nono.nix"
          { services.nonoSandbox.enable = true; }
          "${tsurf}/modules/agent-launcher.nix"
          "${tsurf}/modules/agent-sandbox.nix"
          { services.agentSandbox.enable = true; }
          ./modules/root-ssh.nix
          ./hosts/__TSURF_NODE__/default.nix
        ];
      };

      deploy.nodes."__TSURF_NODE__" = {
        hostname = "__TSURF_TARGET_HOST__";
        sshUser = "__TSURF_SSH_USER__";
        magicRollback = true;
        autoRollback = true;
        confirmTimeout = 300;
        profiles.system = {
          user = "root";
          path = deploy-rs.lib.${system}.activate.nixos self.nixosConfigurations."__TSURF_NODE__";
        };
      };
    };
}
