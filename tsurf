#!/usr/bin/env bash
# tsurf — Convenience launcher for the flake-packaged tsurf CLI.
set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
export TSURF_REPO_DIR="${REPO_DIR}"

if nix eval "${REPO_DIR}#apps.$(nix eval --raw --impure --expr builtins.currentSystem).tsurf.program" >/dev/null 2>&1; then
  exec nix run "${REPO_DIR}#tsurf" -- "$@"
fi

exec bash "${REPO_DIR}/scripts/tsurf.sh" "$@"
